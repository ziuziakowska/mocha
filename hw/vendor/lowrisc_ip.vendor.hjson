{
  name: "lowrisc_ip",
  target_dir: "lowrisc_ip",
  patch_dir: "patches/lowrisc_ip",

  upstream: {
    url: "https://github.com/lowRISC/opentitan"
    // Pinned revision of main branch
    rev: "master"
  }

  mapping: [
    // Utilities.
    {from: "util/basegen",         to: "util/basegen"}, // Dependency of top generator.
    {from: "util/design",          to: "util/design"}, // Dependency of IP generator.
    {from: "util/device_sw_utils", to: "util/device_sw_utils"},
    {from: "util/ipgen.py",        to: "util/ipgen.py"}, // IP generator.
    {from: "util/ipgen",           to: "util/ipgen"},
    {from: "util/raclgen",         to: "util/raclgen"}, // Dependency of top generator.
    {from: "util/reggen",          to: "util/reggen"}, // Dependency of crossbar generator.
    {from: "util/regtool.py",      to: "util/regtool.py", patch_dir: "util_regtool"},
    {from: "util/tlgen.py",        to: "util/tlgen.py"}, // Crossbar generator.
    {from: "util/tlgen",           to: "util/tlgen"},
    {from: "util/topgen",          to: "util/topgen"}, // Dependency of IP generator.
    {from: "util/version_file.py", to: "util/version_file.py"}, // Dependency of top generator.

    // Hardware IP blocks.
    {from: "hw/ip/lc_ctrl",    to: "ip/lc_ctrl"}, // Dependency of crossbar.
    {from: "hw/ip/rv_timer",   to: "ip/rv_timer", patch_dir: "rv_timer"}, // Timer.
    {from: "hw/ip/spi_device", to: "ip/spi_device", patch_dir: "spi_device"}, // SPI device.
    {from: "hw/ip/tlul",       to: "ip/tlul", patch_dir: "tlul"}, // Memory bus.
    {from: "hw/ip/uart",       to: "ip/uart", patch_dir: "uart"}, // Serial input and output.

    // Hardware IP templates.
    {from: "hw/ip_templates/rv_plic", to: "ip_templates/rv_plic"},

    // Primitives.
    {from: "hw/ip/prim",         to: "ip/prim", patch_dir: "prim"},
    {from: "hw/ip/prim_generic", to: "ip/prim_generic"},
    {from: "hw/ip/prim_xilinx",  to: "ip/prim_xilinx"},

    // Lint.
    {from: "hw/lint", to: "lint", patch_dir: "lint"},

    // Simulation.
    {from: "hw/dv/dpi/spidpi",  to: "dv/dpi/spidpi"},
    {from: "hw/dv/dpi/uartdpi", to: "dv/dpi/uartdpi"},
    {from: "hw/dv/sv",          to: "dv/sv", patch_dir: "dv_sv"},
    {from: "hw/dv/verilator",   to: "dv/verilator", patch_dir: "dv_verilator"},

    // Verification.
    {from: "hw/dv/tools",       to: "dv/tools",     patch_dir: "dv_tools"},
    {from: "hw/formal/tools",   to: "formal/tools", patch_dir: "formal_tools"},
  ],

  exclude_from_upstream: [
    "*/BUILD",
    "hw/dv/tools/vcs",
  ],
}
