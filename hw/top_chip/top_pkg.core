name: "lowrisc:mocha_constants:top_pkg"
description: "Toplevel-wide constants for Mocha"
virtual:
  - lowrisc:virtual_constants:top_pkg

filesets:
  files_rtl:
    depend:
      - pulp-platform.org::axi
    files:
      - rtl/top_pkg.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_rtl
