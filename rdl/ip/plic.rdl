            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_24[24:24];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_25[25:25];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_26[26:26];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_27[27:27];
        field {
