        } E_30[30:30];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_31[31:31];
    } IE0[1] @ 0x2000;

    reg {
        compacted = true;
        desc = "Interrupt Enable for Target 1";
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_0[0:0];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_1[1:1];
