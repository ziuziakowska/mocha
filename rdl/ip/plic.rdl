            desc = "Interrupt Pending of Source";
        } P_30[30:30];
        field {
            sw = r;
            hw = w;
            reset = 0x0;
            desc = "Interrupt Pending of Source";
        } P_31[31:31];
    } IP[1] @ 0x1000;

    reg {
        compacted = true;
        desc = "Interrupt Enable for Target 0";
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_0[0:0];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_1[1:1];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_2[2:2];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_3[3:3];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_4[4:4];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Interrupt Enable of Source";
        } E_5[5:5];
        field {
            sw = rw;
